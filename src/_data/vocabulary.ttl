spav:rssfn a rico:RecordSetType, skos:Concept;
  rico:name "sub-fonds"@en, "sous-fonds"@fr, "sub-fondo"@it;
  skos:narrower spav:rsssf;
  skos:broader spav:rsfnd;
  skos:editorialNote "\"A subdivision of a fonds containing a body of related records corresponding to administrative subdivisions in the originating agency or organization or, when that is not possible, to geographical, chronological, functional, or similar groupings of the material itself. When the creating body has a complex hierarchical structure, each sub-fonds has as many subordinate sub-fonds as are necessary to reflect the levels of the hierarchical structure of the primary subordinate administrative unit.\" (ISAD-G, 2nd end.)"@en;
  skos:inScheme spav:rs;
  skos:notation "sfn";
  skos:prefLabel "Teilbestand"@de, "sub-fonds"@en, "sous-fonds"@fr, "sub-fondo"@it .

