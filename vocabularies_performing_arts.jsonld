.w3.org/2004/02/skos/core#notation":[{"@value":"rs"}],"http://purl.org/dc/terms/subject":[{"@id":"http://vocab.performing-arts.ch/vscoll"}],"http://purl.org/dc/terms/coverage":[{"@id":"https://www.ica.org/standards/RiC/ontology#RecordSet"},{"@id":"https://www.ica.org/standards/RiC/ontology#Record"},{"@id":"https://www.ica.org/standards/RiC/ontology#RecordPart"}],"http://purl.org/dc/terms/isRequiredBy":[{"@id":"https://www.ica.org/standards/RiC/ontology#hasRecordSetType"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"archival level","@language":"en"},{"@value":"Archivebene","@language":"de"},{"@value":"niveau archives","@language":"fr"}],"http://www.w3.org/2004/02/skos/core#hasTopConcept":[{"@id":"http://vocab.performing-arts.ch/rstyp"},{"@id":"http://vocab.performing-arts.ch/rsitm"}]},{"@id":"http://vocab.performing-arts.ch/rsarc","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"arc"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"archive","@language":"en"},{"@value":"Archiv","@language":"de"},{"@value":"archives","@language":"fr"},{"@value":"archivio","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"archive","@language":"en"},{"@value":"archives","@language":"fr"},{"@value":"archivio","@language":"it"}],"http://www.w3.org/2004/02/skos/core#exactMatch":[{"@id":"http://www.wikidata.org/entity/Q166118"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rsclt","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"clt"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"collection","@language":"en"},{"@value":"Sammlung","@language":"de"},{"@value":"collection","@language":"fr"},{"@value":"collezione","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"collection","@language":"en"},{"@value":"collection","@language":"fr"},{"@value":"collezione","@language":"it"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"An artificial assemblage of documents accumulated on the basis of some common characteristic without regard to the provenance of those documents. Not to be confused with an archival fonds.\" (ISAD-G, 2nd end.)","@language":"en"}],"http://www.w3.org/2004/02/skos/core#exactMatch":[{"@id":"https://www.ica.org/standards/RiC/vocabularies/recordSetTypes#Collection"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rsfil","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"fil"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"file","@language":"en"},{"@value":"Dossier","@language":"de"},{"@value":"dossier","@language":"fr"},{"@value":"dossier","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"file","@language":"en"},{"@value":"dossier","@language":"fr"},{"@value":"dossier","@language":"it"}],"http://www.w3.org/2004/02/skos/core#altLabel":[{"@value":"dossier","@language":"en"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"An organized unit of documents grouped together either for current use by the creator or in the process of archival arrangement, because they relate to the same subject, activity, or transaction. A file is usually the basic unit within a record series.\" (ISAD-G, 2nd end.)","@language":"en"}],"http://www.w3.org/2004/02/skos/core#exactMatch":[{"@id":"https://www.ica.org/standards/RiC/vocabularies/recordSetTypes#File"},{"@id":"http://www.wikidata.org/entity/Q19515368"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rsfnd","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"fnd"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"fonds","@language":"en"},{"@value":"Bestand","@language":"de"},{"@value":"fonds","@language":"fr"},{"@value":"fondo","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"fonds","@language":"en"},{"@value":"fonds","@language":"fr"},{"@value":"fondo","@language":"it"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"The whole of the records, regardless of form or medium, organically created and/or accumulated and used by a particular person, family, or corporate body in the course of that creator’s activities and functions.\" (ISAD-G, 2nd ed.)","@language":"en"}],"http://www.w3.org/2004/02/skos/core#exactMatch":[{"@id":"https://www.ica.org/standards/RiC/vocabularies/recordSetTypes#Fonds"},{"@id":"http://www.wikidata.org/entity/Q3052382"}],"http://www.w3.org/2004/02/skos/core#narrower":[{"@id":"http://vocab.performing-arts.ch/rssfn"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rsitm","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"itm"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"document","@language":"en"},{"@value":"Dokument","@language":"de"},{"@value":"document","@language":"fr"},{"@value":"documento","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"document","@language":"en"},{"@value":"document","@language":"fr"},{"@value":"documento","@language":"it"}],"http://www.w3.org/2004/02/skos/core#altLabel":[{"@value":"record","@language":"en"},{"@value":"item","@language":"en"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"Recorded information in any form or medium, created or received and maintained, by an organization or person in the transaction of business or the conduct of affairs.\" (ISAD-G, 2nd end.)","@language":"en"}],"http://www.w3.org/2004/02/skos/core#exactMatch":[{"@id":"http://www.wikidata.org/entity/Q11723795"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}],"http://www.w3.org/2004/02/skos/core#topConceptOf":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rssct","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"sct"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"section","@language":"en"},{"@value":"Hauptabteilung","@language":"de"},{"@value":"section","@language":"fr"},{"@value":"sezione","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"section","@language":"en"},{"@value":"section","@language":"fr"},{"@value":"sezione","@language":"it"}],"http://www.w3.org/2004/02/skos/core#narrower":[{"@id":"http://vocab.performing-arts.ch/rsssc"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rssfn","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"sfn"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rsfnd"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"sub-fonds","@language":"en"},{"@value":"Teilbestand","@language":"de"},{"@value":"sous-fonds","@language":"fr"},{"@value":"sub-fondo","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"sub-fonds","@language":"en"},{"@value":"sous-fonds","@language":"fr"},{"@value":"sub-fondo","@language":"it"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"A subdivision of a fonds containing a body of related records corresponding to administrative subdivisions in the originating agency or organization or, when that is not possible, to geographical, chronological, functional, or similar groupings of the material itself. When the creating body has a complex hierarchical structure, each sub-fonds has as many subordinate sub-fonds as are necessary to reflect the levels of the hierarchical structure of the primary subordinate administrative unit.\" (ISAD-G, 2nd end.)","@language":"en"}],"http://www.w3.org/2004/02/skos/core#narrower":[{"@id":"http://vocab.performing-arts.ch/rsssf"}],"http://www.w3.org/2004/02/skos/core#inScheme":[{"@id":"http://vocab.performing-arts.ch/rs"}]},{"@id":"http://vocab.performing-arts.ch/rssrs","@type":["http://www.w3.org/2004/02/skos/core#Concept"],"http://www.w3.org/2004/02/skos/core#notation":[{"@value":"srs"}],"http://www.w3.org/2004/02/skos/core#broader":[{"@id":"http://vocab.performing-arts.ch/rstyp"}],"http://www.w3.org/2004/02/skos/core#prefLabel":[{"@value":"series","@language":"en"},{"@value":"Serie","@language":"de"},{"@value":"série","@language":"fr"},{"@value":"serie","@language":"it"}],"https://www.ica.org/standards/RiC/ontology#name":[{"@value":"series","@language":"en"},{"@value":"série","@language":"fr"},{"@value":"serie","@language":"it"}],"http://www.w3.org/2004/02/skos/core#editorialNote":[{"@value":"\"Documents arranged in accordance with a filing system or maintained as a unit because they result from the same accumulation or filing process, or the same activity; have a particular form; or because of some other relationship arising out of their creation, receipt, or use. A series is also known as a records series.\" 